<!DOCTYPE html>
<html>
<head>
    <title><%=movie["title"]%> - MovReview</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <header>
        <nav>
            <div class="nav-logo">MovReview</div>
            <div class="nav-links">
                <a href="/watchlist" class="btn btn-outline">My Watchlist</a>
                <a href="/watched" class="btn btn-outline">Watched</a>
                <a href="/account-settings" class="btn btn-outline">Settings</a>
                <a href="/logout" class="btn btn-danger">Logout</a>
            </div>
        </nav>
    </header>

    <div class="container">
        <div class="flex justify-between items-center mb-20">
            <div>
                <p>Logged in as: <strong><%= user.email %></strong> <span class="badge"><%= user.role %></span></p>
            </div>
        </div>

        <div class="card">
            <h1><%=movie.title%></h1>
            <p><strong>Rating:</strong> <span class="badge"><%=movie.avgRating%>/5</span> (<%=movie.ratingCount%> ratings)</p>
            <p><strong>Description:</strong></p>
            <p><%=movie.description%></p>
        </div>
      
        <div class="card">
            <h3>Rate & Review</h3>
            <form action="/movies/view" method="post">
                <div class="form-group">
                    <label for="rating">My Rating (1-5)</label>
                    <input type="number" id="rating" name="rating" min="1" max="5" value="<%= user.rating || ''%>">
                </div>
                <div class="form-group">
                    <label for="review">My Review</label>
                    <textarea id="review" name="review" rows="5" placeholder="What did you think?"><%=user.review||''%></textarea>
                </div>
                <input type="hidden" name="movieid" value="<%= movie.selectedMovieid %>">
                <div class="flex gap-10">
                    <button type="submit" class="btn btn-primary">Update Review</button>
                    <a href="/home" class="btn btn-outline">Back to Home</a>
                </div>
            </form>
        </div>

        <div class="card">
            <h4>What people are saying</h4>
            <%
            const reviews = movie.reviews || {};
            const reviewKeys = Object.keys(reviews);
            const reviewCount = reviewKeys.length;
            %>


    <h4>What people are saying</h4>
    <% if (reviewCount === 0) { %>
      <p><em>No reviews yet.</em></p>
    <% } else if (reviewCount === 1 && userHasReviewed) { %>
      <p><em>Only you have left a review.</em></p>
    <% } else { %>
      <%if(user.isAdmin===true){%>
        <form action="/deleteReviews" method="post"><ul>
        <button type="submit">Delete Selected Reviews</button>
        <input type="hidden" name="movieid" value="<%=movie.selectedMovieid%>">
      <%}%>
      
        <% for (let reviewer in reviews) { %>
          <% reviewer1 = reviewer.replace(/_dot_/g, '.') %>
          <% if (reviewer1 === user.email) { %>
            <li>
              <label>
              <strong>You</strong> (Your review): <%= reviews[reviewer] %>
              <%if(user.isAdmin===true){%>
                <input type="checkbox" name="usersToDeleteReviews" value="<%=reviewer1%>">
              <%}%></label>
            </li>
          <% } else { %>
            <li>
              <label>
              <strong><%= reviewer1 %></strong>: <%= reviews[reviewer] %>
              <%if(user.isAdmin===true){%>
                <input type="checkbox" name="usersToDeleteReviews" value="<%=reviewer1%>">
              <%}%></label>
            </li>
          <% } %>
        <% } %>
      </ul>
      
      <%if(user.isAdmin===true){%>
        </form>
      <%}%>
    
    
    <% } %>
    <%# skips the logged-in user's own review%>


                <div style="display: flex; flex-direction: column; gap: 15px;">
                    <% for (let reviewer in reviews) { %>
                        <% let reviewer1 = reviewer.replace(/_dot_/g, '.') %>
                        <div style="padding-bottom: 10px; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: flex-start;">
                            <div style="flex: 1;">
                                <strong><%= reviewer1 === user.email ? 'You' : reviewer1 %></strong>
                                <p style="margin-top: 5px;"><%= reviews[reviewer] %></p>
                            </div>
                            <% if (user.isAdmin) { %>
                                <div style="margin-left: 15px; padding-top: 5px;">
                                    <input type="checkbox" name="usersToDeleteReviews" value="<%= reviewer1 %>" title="Select review by <%= reviewer1 %> to delete">
                                </div>
                            <% } %>
                        </div>
                    <% } %>
                </div>

                <% if (user.isAdmin) { %>
                    </form>
                <% } %>
            <% } %>
        </div>
    </div>
</body>
</html>