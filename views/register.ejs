<!DOCTYPE html>
<html>
    <head>
        <title>Register - MovReview</title>
        <link rel="stylesheet" href="/style.css">
    </head>
    <body>
        <div class="auth-container">
            <h2 style="text-align: center;">Join MovReview</h2>

            <% if (typeof(e) === typeof("a")) { %>
                <div class="alert alert-danger"><%=e%></div>
            <% } %>

            <form method="post" action="/register">
                <div class="form-group">
                    <label for="user">Email</label>
                    <input type="text" id="user" name="user" value = "<%=user%>">
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password">
                </div>
                <div class="form-group">
                    <label for="cpassword">Confirm Password</label>
                    <input type="password" id="cpassword" name="cpassword">
                </div>

                <div class="form-group">
                    <label>Role</label>
                    <div class="flex gap-10">
                        <label class="flex items-center gap-10">
                            <input type="radio" name="role" value="admin" style="width: auto;"
                                <%if(role=="admin"){%>
                                    checked
                                <%}%>
                            > Admin
                        </label>
                        <label class="flex items-center gap-10">
                            <input type="radio" name="role" value="user" style="width: auto;"
                                <%if(role=="user"){%>
                                    checked
                                <%}%>
                            > User
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100">Create account</button>
            </form>

            <div style="text-align: center; margin-top: 20px;">
                <p>Already have an account?</p>
                <a href="/login" class="btn btn-outline w-100">Return to Login Page</a>
            </div>
        </div>
    </body>
</html>