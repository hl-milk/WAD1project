<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Watched Movies</title>
</head>
<body>
    <h2>My Watched Movies</h2>
    <br>
    <a href="/home">
        <button type="button">Back to Home</button>
    </a>
    <br><br>
    
    <% if (activeMovies.length === 0) { %>
        <p>You haven't watched any movies yet.</p>
    <% } else { %>
        <ul>
            <% activeMovies.forEach(function(movie) { %>
                <li>
                    <h3>Movie: <%= movie.movieName %></h3>
                    
                    <% if (movie.rating === 0) { %>
                        <p><strong>Your Rating:</strong> Unrated</p>
                    <% } else { %>
                        <p><strong>Your Rating:</strong> <%= movie.rating %> / 5 Stars</p>
                    <% } %>
                    
                    <form action="/watched/trash" method="POST">
                        <input type="hidden" name="movieId" value="<%= movie.movieId %>">
                        <button type="submit">Mark as to delete</button>
                    </form>
                    <hr>
                </li>
            <% }); %>
        </ul>
    <% } %>

    <% if (trashMovies && trashMovies.length > 0) { %>
        <div>
            <h3>Pending Deletion</h3>
            <ul>
                <% trashMovies.forEach(function(movie) { %>
                    <li><%= movie.movieName %></li>
                <% }); %>
            </ul>
            <br>
            <form action="/watched/empty-trash" method="POST">
                <button type="submit">Confirm Delete All</button>
            </form>
        </div>
    <% } %>

</body>
</html>