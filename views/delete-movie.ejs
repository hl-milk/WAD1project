<!DOCTYPE html>
<html>
<head>
    <title>Movie Deleted - MovReview</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <header>
        <nav>
            <div class="nav-logo">MovReview</div>
            <div class="nav-links">
                <a href="/watchlist" class="btn btn-outline">My Watchlist</a>
                <a href="/watched" class="btn btn-outline">Watched</a>
                <a href="/account-settings" class="btn btn-outline">Settings</a>
                <a href="/logout" class="btn btn-danger">Logout</a>
            </div>
        </nav>
    </header>

    <div class="container">
        <div class="card">
            <h1 class="alert alert-success">Movie Deleted Successfully</h1>

            <div class="form-group">
                <label>Movie Name</label>
                <input type="text" value="<%= moviename %>" disabled>
            </div>
            
            <div class="form-group">
                <label>Movie ID</label>
                <input type="text" value="<%= movieid %>" disabled>
            </div>

            <div class="mt-20">
                <a href="/home" class="btn btn-primary">Back to Home</a>
            </div>
        </div>
    </div>
</body>
</html>