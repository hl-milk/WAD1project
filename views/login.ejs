<!DOCTYPE html>
<html>
    <head>
        <title>Login - MovReview</title>
        <link rel="stylesheet" href="/style.css">
    </head>
    <body>
        <div class="auth-container">
            <h2 style="text-align: center;">Welcome to MovReview</h2>
            
            <% if (typeof(e) === typeof("a")) { %>
                <div class="alert alert-danger"><%=e%></div>
            <% } %>
            <% if (e === 1) { %>
                <div class="alert alert-success">Successfully registered! Please login.</div>
            <% } %>
            <% if (e === 2) {%>
                <div class="alert alert-danger">Please login with an account!</div>
            <% } %>
            <% if (e === 3) {%>
                <div class="alert alert-success">Account successfully deleted!</div>
            <% } %>

            <form method="post" action="/login">
                <div class="form-group">
                    <label for="user">Email</label>
                    <input type="text" id="user" name="user">
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password">
                </div>
                <button type="submit" class="btn btn-primary w-100">Login</button>
            </form>

            <div style="text-align: center; margin-top: 20px;">
                <p>Don't have an account?</p>
                <a href="/register" class="btn btn-outline w-100">Register for a new account</a>
            </div>
        </div>
    </body>
</html>