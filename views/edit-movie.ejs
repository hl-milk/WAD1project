<!DOCTYPE html>
<html>
<head>
    <title>Edit Movie</title>
</head>
<body>
    <h2>Edit Movie</h2>

    <% if (error) { %>
        <p style="color:red;"><%= error %></p>
    <% } %>

    <% if (success) { %>
        <p style="color:green;"><%= success %></p>
    <% } %>

    <form method="post" action="/movies/edit">
        <input type="hidden" name="movieid" value="<%= movie.movieid %>">

        <label>
            Movie Name:
            <input type="text" name="moviename" value="<%= movie.moviename %>" required>
        </label>
        <br><br>

        <label>
            Movie ID:
            <input type="text" value="<%= movie.movieid %>" disabled>
        </label>
        <br><br>

        <label>
            Description:
            <textarea name="description" required><%= movie.description %></textarea>
        </label>
        <br><br>

        <label>
            Genre:
            <select name="genre" required>
                <% genres.forEach(g => { %>
                    <option value="<%= g %>" <%= movie.genre === g ? "selected" : "" %>>
                        <%= g %>
                    </option>
                <% }) %>
            </select>
        </label>
        <br><br>

        <button type="submit">Update Movie</button>
    </form>

    <br>

    <form method="post" action="/movies/delete?movieid=<%= movie.movieid %>">
        <button type="submit" style="color:red;">Delete Movie</button>
    </form>

    <br>
    <a href="/home"><button type="button">Back to Home</button></a>
</body>
</html>