<!DOCTYPE html>
<html>
    <head>
        <title>Home</title>
    </head>
    <body>
        <h2>Welcome to MovieReview</h2>

        <p>Logged in as: <%= user.email %> (<%= user.role %>)</p>

        <a href="/account-settings"><button type="button">Account Settings</button></a>
        <a href="/logout"><button type="button">Logout</button></a>

        <hr>

        <form method="get" action="/home">
            <label>
                Search Movie:
                <input type="text" name="search" value="<%= search %>">
            </label>

            <label>
                Genre:
                <select name="genre">
                    <option value="all" <%= genre === "all" ? "selected" : "" %>>All Genres</option>
                    <% genres.forEach(g => { %>
                        <option value="<%= g %>" <%= genre === g ? "selected" : "" %>>
                            <%= g %>
                        </option>
                    <% }) %>
                </select>
            </label>

            <button type="submit">Apply</button>
        </form>

        <br>

        <% if (user && user.role === "admin") { %>
            <a href="/movies/add"><button type="button">Add New Movie</button></a>
            <br><br>
        <% } %>

        <% if (movies.length === 0) { %>
            <p>No movies found.</p>
        <% } %>

        <% movies.forEach(movie => { %>
            <div>
                <a href="/movies/view?movieid=<%=movie.movieid%>"><h3><%= movie.moviename %></h3></a>
                <p><strong>Movie ID:</strong> <%= movie.movieid %></p>
                <p><strong>Description:</strong> <%= movie.description %></p>
                <p><strong>Genre:</strong> <%= movie.genre %></p>

                <% if (user.role === "admin") { %>
                    <a href="/movies/edit?movieid=<%= movie.movieid %>">
                        <button type="button">Edit</button>
                    </a>

                    <form method="post" action="/movies/delete?movieid=<%= movie.movieid %>">
                        <button type="submit">Delete</button>
                    </form>
                <% } %>
            </div>
        <% }) %>
    </body>
</html>