<!DOCTYPE html>
<html>
<head>
    <title>Account Settings - MovReview</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <header>
        <nav>
            <div class="nav-logo">MovReview</div>
            <div class="nav-links">
                <a href="/watchlist" class="btn btn-outline">My Watchlist</a>
                <a href="/watched" class="btn btn-outline">Watched</a>
                <a href="/account-settings" class="btn btn-outline">Settings</a>
                <a href="/logout" class="btn btn-danger">Logout</a>
            </div>
        </nav>
    </header>

    <div class="container">
        <div class="flex justify-between items-center mb-20">
            <h1>Account Settings</h1>
            <a href="/home" class="btn btn-outline">Back to Home</a>
        </div>

        <div class="card">
            <% if (typeof(e) === typeof("a")) { %>
                <div class="alert alert-danger"><%=e%></div>
            <% } %>
            <% if (e === 1) { %>
                <div class="alert alert-success">Successfully updated password!</div>
            <% } %>

            <h3>Change Password</h3>
            <form method="post" action="/account-settings">
                <div class="form-group">
                    <label for="password">New Password</label>
                    <input type="password" id="password" name="password">
                </div>
                <div class="form-group">
                    <label for="cpassword">Confirm Password</label>
                    <input type="password" id="cpassword" name="cpassword">
                </div>
                <div class="flex gap-10">
                    <button type="submit" class="btn btn-primary">Change password</button>
                </div>
            </form>
        </div>

        <div class="card" style="border-top: 5px solid var(--danger-color);">
            <h3 style="color: var(--danger-color);">Account Management</h3>
            <p>Once you delete your account, there is no going back. Please be certain.</p>
            <div class="flex gap-10 mt-20">
                <a href="/delete-account" class="btn btn-danger">Delete account</a>
            </div>
        </div>
    </div>
</body>
</html>