<!DOCTYPE html>
<html>
  <head>
    <title>My Watchlist</title>
  </head>
  <body>
    <h2><%= user.email %>'s Watchlist</h2>
    
    <% if (msg === "removed") { %>
      <p style="color: green;">Movie removed from watchlist successfully!</p>
    <% } else if (msg === "watched") { %>
      <p style="color: green;">Movie marked as watched and moved from watchlist!</p>
    <% } %>
    
    <a href="/home"><button type="button">Back to Home</button></a>
    <a href="/logout"><button type="button">Logout</button></a>
    <hr>

    <% if (!movies || movies.length === 0) { %>
      <p>Your watchlist is empty.</p>
    <% } else { %>
      <% movies.forEach(movie => { %>
        <div>
          <h3><%= movie.moviename %></h3>
          <p><strong>Movie ID:</strong> <%= movie.movieid %></p>
          <p><strong>Description:</strong> <%= movie.description %></p>
          <p><strong>Genre:</strong> <%= movie.genre %></p>

          <!-- Action buttons -->
          <form method="post" action="/watchlist/watched?movieid=<%= movie.movieid %>" style="display:inline;">
            <button type="submit">Mark as Watched</button>
          </form>
          <form method="post" action="/watchlist/remove?movieid=<%= movie.movieid %>" style="display:inline;">
            <button type="submit">Remove from Watchlist</button>
          </form>

          <!-- NEW 3.2: Review/View buttons (match Noah/Cesar routes) -->
          <br>
          <a href="/movies/view?movieid=<%= movie.movieid %>" style="display:inline;">
            <button type="button">View Details & Reviews</button>
          </a>
          <a href="/reviews/new?movieid=<%= movie.movieid %>" style="display:inline;">
            <button type="button">Write a Review</button>
          </a>
        </div>
        <hr>
      <% }) %>
    <% } %>
  </body>
</html>
